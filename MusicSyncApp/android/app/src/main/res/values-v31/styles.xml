<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ Splash Screen Theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        
        <!-- Makes the native splash window instantly pitch black -->
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@color/splash_background</item>

        <!-- Use pitch black for the entire splash screen -->
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <!-- Use the branded splash image as the central icon -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_branded</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/splash_background</item>
    </style>
</resources>
